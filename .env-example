# Databricks workspace connection
DATABRICKS_HOST=https://<workspace-host>

# Cloud Provider: AWS, AZURE, or GCP
# This helps skip APIs that are not available in specific clouds
DATABRICKS_CLOUD_PROVIDER=AZURE

# Use username/password (admin)
DATABRICKS_USERNAME=<admin-user>
DATABRICKS_PASSWORD=<admin-password>

# Or use token auth instead of user/password
# DATABRICKS_TOKEN=<pat>

# Output directory for reports (default: ./output)
# If empty or not set, defaults to ./output
# OUTPUT_DIR=./output

# Optional flags for inventory
# INVENTORY_BATCH_SIZE=200
# INVENTORY_BATCH_SLEEP_MS=0
# INVENTORY_INCLUDE_RUNS=0
# INVENTORY_INCLUDE_QUERY_HISTORY=0
# INVENTORY_INCLUDE_DBFS=0
