# Databricks workspace connection
DATABRICKS_HOST=https://<workspace-host>

# Cloud Provider: AWS, AZURE, or GCP
# This helps skip APIs that are not available in specific clouds
DATABRICKS_CLOUD_PROVIDER=AZURE

# OPTION 1: Token Authentication (Personal Access Token)
# Best for: Development, personal scripts
# DATABRICKS_TOKEN=<pat>

# OPTION 2: Username + Password Authentication
# Best for: Admin accounts, interactive use
# DATABRICKS_USERNAME=<admin-user>
# DATABRICKS_PASSWORD=<admin-password>

# OPTION 3: Service Principal Authentication (RECOMMENDED for production/CI-CD)
# Best for: Automation, CI/CD pipelines, scheduled jobs
# Requires: Service Principal created in Databricks Admin Console
# Create at: Admin Console → Identity & Access → Service Principals
# Then: Create a PAT for the Service Principal
# DATABRICKS_CLIENT_ID=<service-principal-id>
# DATABRICKS_CLIENT_SECRET=<service-principal-secret>

# Output directory for reports (default: ./output)
# If empty or not set, defaults to ./output
OUTPUT_DIR=./.reports

# Optional flags for inventory
# INVENTORY_BATCH_SIZE=200
# INVENTORY_BATCH_SLEEP_MS=0
# INVENTORY_INCLUDE_RUNS=0
# INVENTORY_INCLUDE_QUERY_HISTORY=0
# INVENTORY_INCLUDE_DBFS=0
